import requests
import base64

# API Credentials
api_username = "AlbertRogerUK"  # Replace with your Cin7 username
api_key = "d7fa15ce7fde46de82b53fd4dcaea663"  # Replace with your Cin7 API key
connection_key = 'd7fa15ce7fde46de82b53fd4dcaea663'  # Your actual Connection Key
# Encode credentials for Basic Auth
credentials = f"{api_username}:{api_key}"
encoded_credentials = base64.b64encode(credentials.encode('utf-8')).decode('utf-8')

# API URL and credit note reference
BASE_URL = 'https://api.cin7.com/api/v1/PurchaseOrders'
credit_note_reference = "PO-ARL24-2469"  # Replace with your desired credit note reference

# Headers
headers = {
    "Authorization": f"Basic {encoded_credentials}",
    "Content-Type": "application/json"
}

# URL to fetch the credit note by Reference
url = f"{BASE_URL}?Reference={credit_note_reference}"

# Making the GET request
response = requests.get(url, headers=headers)

# Handling the response
if response.status_code == 200:
    # Success: Print the credit note details
    credit_note = response.json()
    print("Credit Note Details:", credit_note)
elif response.status_code == 404:
    print("Credit note not found. Please verify the reference.")
elif response.status_code == 401:
    print("Unauthorized. Please check your API username and key.")
else:
    print(f"Failed to fetch credit note: {response.status_code} - {response.text}")